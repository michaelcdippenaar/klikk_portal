FROM node:22-alpine

WORKDIR /app

COPY mcp/stock-market/server.mjs ./mcp/stock-market/server.mjs

ENV KLIKK_MCP_TRANSPORT=http
ENV KLIKK_MCP_HTTP_HOST=0.0.0.0
ENV KLIKK_MCP_HTTP_PORT=8787
ENV KLIKK_API_BASE_URL=https://console.8-bit.space/backend

EXPOSE 8787

CMD ["node", "mcp/stock-market/server.mjs"]
